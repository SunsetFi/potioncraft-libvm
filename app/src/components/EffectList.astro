---
import { Image } from "astro:assets";
import { resolveEffectIcon } from "../content/effects/resolve-effect-icon";
import { getEffectHref } from "../content/effects/effect-href";
import { resolveEffect } from "../content/effects/resolve-effect";
import type { EffectTierRecord } from "../content/effects/types/EffectTierRecord";
import { recordKeys } from "../utils/record-keys";
import { recordEntries } from "../utils/record-entries";

import LinkSwitch from "./LinkSwitch.astro";

interface Props {
  class?: string;
  effects: EffectTierRecord;
  link?: boolean;
}

const { effects, link = true } = Astro.props;

const effectData = Object.fromEntries(
  await Promise.all(
    recordKeys(effects).map(async (id) => {
      const [effect, icon] = await Promise.all([
        resolveEffect(id),
        resolveEffectIcon(id),
      ]);
      return [id, { effect, icon }];
    }),
  ),
);
---

<ul class={`effect-list not-content ${Astro.props.class ?? ""}`}>
  {
    recordEntries(effects).map(([id, strength]) =>
      Array.from({ length: strength }, () => (
        <LinkSwitch link={link} href={getEffectHref(id)}>
          {effectData[id]?.icon ? (
            <Image
              class="recipe-effect-icon"
              src={effectData[id].icon}
              alt={effectData[id].effect.data.name}
              title={effectData[id].effect.data.name}
              width={32}
              height={32}
            />
          ) : (
            <div
              class="recipe-effect-icon"
              style={{
                width: "32px",
                height: "32px",
                backgroundColor: "#ccc",
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                fontSize: "12px",
                color: "#333",
              }}
              title={effectData[id]?.effect.data.name}
            >
              {effectData[id]?.effect.data.name ?? id}
            </div>
          )}
        </LinkSwitch>
      )),
    )
  }
</ul>
<style>
  .effect-list {
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
</style>
