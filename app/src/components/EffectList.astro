---
import { Image } from "astro:assets";
import { resolveEffectIcon } from "../content/effects/resolve-effect-icon";
import { effectHref } from "../content/effects/effect-href";
import { resolveEffect } from "../content/effects/resolve-effect";

interface Props {
  effects: Record<string, number>;
}

const { effects } = Astro.props;

const effectData = Object.fromEntries(
  await Promise.all(
    Object.keys(effects).map(async (id) => {
      const [effect, icon] = await Promise.all([
        resolveEffect(id),
        resolveEffectIcon(id),
      ]);
      return [id, { effect, icon }];
    }),
  ),
);
---

<ul class="effect-list">
  {
    Object.entries(effects).map(([id, strength]) =>
      Array.from({ length: strength }, () => (
        <a href={effectHref(id)}>
          {effectData[id]?.icon ? (
            <Image
              class="recipe-effect-icon"
              src={effectData[id].icon}
              alt={effectData[id].effect.data.name}
              width={32}
              height={32}
            />
          ) : (
            <div
              class="recipe-effect-icon"
              style={{
                width: "32px",
                height: "32px",
                backgroundColor: "#ccc",
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                fontSize: "12px",
                color: "#333",
              }}
            >
              {effectData[id]?.effect.data.name ?? id}
            </div>
          )}
        </a>
      )),
    )
  }
</ul>
<style>
  .effect-list {
    padding: 0;
    list-style: none;
    display: flex;
    gap: 0.25rem;
  }
</style>
