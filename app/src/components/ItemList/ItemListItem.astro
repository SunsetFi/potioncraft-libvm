---
import { Image } from "astro:assets";

interface Props {
  title: string;
  href: string;
  icon?: ImageMetadata | null;
}

const { title, href, icon } = Astro.props;
---

<a class="item-icon-list-item" href={href}>
  <h5 class="item-icon-list-item-name">{title}</h5>
  {
    icon && (
      <div class="effects-item-icon">
        <Image src={icon} alt={title} width={64} />
      </div>
    )
  }
  <slot />
</a>
<style>
  .item-icon-list-item {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    padding: 18px;
    margin: 4px;
    width: 170px;
    height: var(--item-height, 200px);
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  .item-icon-list-item-name {
    text-align: center;
    margin-bottom: 0.5rem;
  }
</style>
