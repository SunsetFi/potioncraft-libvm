---
import type { CollectionEntry } from "astro:content";
import EffectList from "./EffectList.astro";
import RecipeTagsList from "./RecipeTagsList.astro";
import IngredientList from "./IngredientList.astro";
import { getRecipeHref } from "../content/recipes/recipe-href";
import { resolveEffects } from "../content/effects/resolve-effect";
import { resolveTags } from "../content/tags/resolve-tag";
import { resolveIngredients } from "../content/ingredients/resolve-ingredient";
import SaltsList from "./SaltsList.astro";

interface Props {
  recipes: CollectionEntry<"recipes">[];
  allowSorting?: boolean;
}

const { recipes, allowSorting = true } = Astro.props;
const [allTags, allIngredients, allEffects] = await Promise.all([
  resolveTags(),
  resolveIngredients(),
  resolveEffects(),
]);
---

<div class="recipes-table-container">
  <div class="recipes-table-filters">
    <select aria-label="Filter Effects" data-filter="effect">
      <option value="">All Effects</option>
      {allEffects.map((eff) => <option value={eff.id}>{eff.data.name}</option>)}
    </select>
    <select aria-label="Filter Tags" data-filter="tag">
      <option value="">All Tags</option>
      {allTags.map((tag) => <option value={tag.id}>{tag.data.name}</option>)}
    </select>
    <select aria-label="Filter Ingredients" data-filter="ingredient">
      <option value="">All Ingredients</option>
      {
        allIngredients.map((ing) => (
          <option value={ing.id}>{ing.data.name}</option>
        ))
      }
    </select>
    <select aria-label="Filter Salt Usage" data-filter="salt-usage">
      <option value="">Any Salts</option>
      <option value="low-salts">Low Salts</option>
      <option value="no-salts">No Salts</option>
    </select>
    {
      allowSorting && (
        <select aria-label="Sort By" data-filter="sort">
          <option value="cost">Sort by Cost</option>
          <option value="ingredient-count">Sort by Ingredient Count</option>
        </select>
      )
    }
  </div>
  <table class="recipes-table">
    <thead>
      <tr>
        <th>Effects</th>
        <th>Tags</th>
        <th>Ingredients</th>
        <th>Salts</th>
        <th>Cost</th>
        <th>Link</th>
      </tr>
    </thead>
    <tbody>
      {
        recipes.map(
          ({ id, data: { effects, tags, ingredients, salts, cost } }) => (
            <tr
              data-tags={tags.join(" ")}
              data-ingredients={Object.keys(ingredients)
                .map((x) => x.toLowerCase())
                .join(" ")}
              data-effects={Object.keys(effects)
                .map((x) => x.toLowerCase())
                .join(" ")}
              data-cost={cost}
              data-ingredient-count={Object.values(ingredients).reduce(
                (a, b) => a + b,
                0,
              )}
              data-salt-count={Object.values(salts).reduce((a, b) => a + b, 0)}
            >
              <td>
                <EffectList effects={effects} />
              </td>
              <td>
                <RecipeTagsList tags={tags} limit={3} />
              </td>
              <td>
                <IngredientList ingredients={ingredients} count={true} />
              </td>
              <td>
                <SaltsList salts={salts} />
              </td>
              <td>
                <span title={String(cost)}>{cost.toFixed(2)}</span>
              </td>
              <td>
                <a href={getRecipeHref(id)}>View</a>
              </td>
            </tr>
          ),
        )
      }
    </tbody>
  </table>
</div>

<script>
  document
    .querySelectorAll<HTMLElement>(".recipes-table-container")
    .forEach((container) => {
      const tbody = container.querySelector<HTMLElement>(
        ".recipes-table tbody",
      )!;
      const tagSel = container.querySelector<HTMLSelectElement>(
        '[data-filter="tag"]',
      );
      const ingSel = container.querySelector<HTMLSelectElement>(
        '[data-filter="ingredient"]',
      );
      const effSel = container.querySelector<HTMLSelectElement>(
        '[data-filter="effect"]',
      );
      const saltSel = container.querySelector<HTMLSelectElement>(
        '[data-filter="salt-usage"]',
      );
      const sortSel = container.querySelector<HTMLSelectElement>(
        '[data-filter="sort"]',
      );

      function applyFilters() {
        tbody.querySelectorAll<HTMLTableRowElement>("tr").forEach((row) => {
          const matchTag =
            !tagSel?.value ||
            row.dataset.tags?.split(" ").includes(tagSel.value);
          const matchIng =
            !ingSel?.value ||
            row.dataset.ingredients?.split(" ").includes(ingSel.value);
          const matchEff =
            !effSel?.value ||
            row.dataset.effects?.split(" ").includes(effSel.value);

          let matchSalts = true;
          switch (saltSel?.value) {
            case "low-salts":
              matchSalts = Number(row.dataset.saltCount) <= 500;
              break;
            case "no-salts":
              matchSalts = Number(row.dataset.saltCount) === 0;
              break;
          }
          row.style.display =
            matchTag && matchIng && matchEff && matchSalts ? "" : "none";
        });
      }

      tagSel?.addEventListener("change", applyFilters);
      ingSel?.addEventListener("change", applyFilters);
      effSel?.addEventListener("change", applyFilters);
      saltSel?.addEventListener("change", applyFilters);

      sortSel?.addEventListener("change", () => {
        const primaryKey =
          sortSel.value === "cost" ? "cost" : "ingredientCount";
        const secondaryKey = primaryKey === "cost" ? "ingredientCount" : "cost";
        const rows = [...tbody.querySelectorAll<HTMLTableRowElement>("tr")];
        rows.sort((a, b) => {
          const primaryDiff =
            Number(a.dataset[primaryKey]) - Number(b.dataset[primaryKey]);
          return primaryDiff !== 0
            ? primaryDiff
            : Number(a.dataset[secondaryKey]) - Number(b.dataset[secondaryKey]);
        });
        rows.forEach((r) => tbody.appendChild(r));
      });
    });
</script>

<style>
  .recipes-table-container {
    container-type: inline-size;
  }

  .recipes-table {
    overflow: visible;
  }

  .recipes-table-filters {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    margin-bottom: 0.75rem;
  }

  @container (max-width: 40rem) {
    .recipes-table-filters {
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: center;
      gap: 0.4rem 0.75rem;
    }
  }
</style>
