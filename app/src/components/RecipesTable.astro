---
import type { CollectionEntry } from "astro:content";
import EffectList from "./EffectList.astro";
import RecipeTagsList from "./RecipeTagsList.astro";
import IngredientList from "./IngredientList.astro";
import { getRecipeHref } from "../content/recipes/recipe-href";
import { resolveEffects } from "../content/effects/resolve-effect";
import { resolveTags } from "../content/tags/resolve-tag";
import { resolveIngredients } from "../content/ingredients/resolve-ingredient";

interface Props {
  recipes: CollectionEntry<"recipes">[];
}

const { recipes } = Astro.props;
const [allTags, allIngredients, allEffects] = await Promise.all([
  resolveTags(),
  resolveIngredients(),
  resolveEffects(),
]);
---

<div class="recipes-table-container">
  <div class="recipes-table-filters">
    <label for="tag-filter">Tag:</label>
    <select id="tag-filter">
      <option value="">All</option>
      {allTags.map((tag) => <option value={tag.id}>{tag.data.name}</option>)}
    </select>
    <label for="ingredient-filter">Ingredient:</label>
    <select id="ingredient-filter">
      <option value="">All</option>
      {
        allIngredients.map((ing) => (
          <option value={ing.id}>{ing.data.name}</option>
        ))
      }
    </select>
    <label for="effect-filter">Effect:</label>
    <select id="effect-filter">
      <option value="">All</option>
      {allEffects.map((eff) => <option value={eff.id}>{eff.data.name}</option>)}
    </select>
  </div>
  <table class="recipes-table">
    <thead>
      <tr>
        <th>Effects</th>
        <th>Tags</th>
        <th>Ingredients</th>
        <th>Link</th>
      </tr>
    </thead>
    <tbody>
      {
        recipes.map(({ id, data: { effects, tags, ingredients } }) => (
          <tr
            data-tags={tags.join(" ")}
            data-ingredients={Object.keys(ingredients)
              .map((x) => x.toLowerCase())
              .join(" ")}
            data-effects={Object.keys(effects)
              .map((x) => x.toLowerCase())
              .join(" ")}
          >
            <td>
              <EffectList effects={effects} />
            </td>
            <td>
              <RecipeTagsList tags={tags} limit={3} />
            </td>
            <td>
              <IngredientList ingredients={ingredients} />
            </td>
            <td>
              <a href={getRecipeHref(id)}>View</a>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<script>
  const tagSel = document.getElementById("tag-filter") as HTMLSelectElement;
  const ingSel = document.getElementById(
    "ingredient-filter",
  ) as HTMLSelectElement;
  const effSel = document.getElementById("effect-filter") as HTMLSelectElement;

  function applyFilters() {
    document
      .querySelectorAll<HTMLTableRowElement>(".recipes-table tbody tr")
      .forEach((row) => {
        const matchTag =
          !tagSel.value || row.dataset.tags?.split(" ").includes(tagSel.value);
        const matchIng =
          !ingSel.value ||
          row.dataset.ingredients?.split(" ").includes(ingSel.value);
        const matchEff =
          !effSel.value ||
          row.dataset.effects?.split(" ").includes(effSel.value);
        row.style.display = matchTag && matchIng && matchEff ? "" : "none";
      });
  }

  tagSel.addEventListener("change", applyFilters);
  ingSel.addEventListener("change", applyFilters);
  effSel.addEventListener("change", applyFilters);
</script>

<style>
  .recipes-table {
    overflow: visible;
  }

  .recipes-table-filters {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    margin-bottom: 0.75rem;
  }
</style>
