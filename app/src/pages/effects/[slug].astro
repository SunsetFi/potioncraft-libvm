---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

import { resolveEffectIcon } from "../../content/effects/resolve-effect-icon";
import { getRecipesByEffect } from "../../content/recipes/recipes-by-effect";

import RecipesTable from "../../components/RecipesTable.astro";
import ExpandableContent from "../../components/ExpandableContent.astro";

export async function getStaticPaths() {
  const effects = await getCollection("effects");
  return effects.map((effect) => ({
    params: { slug: effect.id },
    props: { effect: effect },
  }));
}

const { effect } = Astro.props;
const { id } = effect;
const { name, basePrice } = effect.data;

const [{ Content }, resolvedIcon, recipes] = await Promise.all([
  render(effect),
  resolveEffectIcon(id),
  getRecipesByEffect(id),
]);
---

<StarlightPage
  frontmatter={{
    title: name,
    description: `The ${name} effect.`,
  }}
  headings={[
    { depth: 2, slug: "recipes", text: "Recipes" },
    { depth: 2, slug: "effect-recipes", text: "Recipes" },
  ]}
>
  <div class="effect-layout">
    <aside class="effect-infobox">
      {
        resolvedIcon && (
          <div class="icon-wrapper">
            <Image src={resolvedIcon} alt={name} width={64} />
          </div>
        )
      }
      <dl>
        <dt>Base Price</dt>
        <dd>{basePrice}</dd>
      </dl>
    </aside>

    <div class="effect-body">
      <Content />
      {effect.body != null ? <hr /> : null}
      <ExpandableContent
        id="effect-recipes"
        title="Recipes using this Effect"
        collapsed={true}
      >
        <RecipesTable recipes={recipes} />
      </ExpandableContent>
    </div>
  </div>
</StarlightPage>

<style>
  .effect-layout {
    min-height: 200px;
  }

  .effect-infobox {
    float: right;
    width: 200px;
    margin-left: var(--sl-content-pad-x);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    padding: 1rem;
    height: fit-content;
  }

  .icon-wrapper {
    border-radius: 0.25rem;
    padding: 0.5rem;
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  dt {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  dd {
    font-weight: 600;
    margin: 0 0 0.75rem 0;
  }
</style>
