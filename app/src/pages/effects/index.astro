---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { resolveEffects } from "../../content/effects/resolve-effect";
import { resolveEffectIcon } from "../../content/effects/resolve-effect-icon";
import { getEffectHref } from "../../content/effects/effect-href";
import ItemList from "../../components/ItemList/ItemList.astro";
import ItemListItem from "../../components/ItemList/ItemListItem.astro";

const effects = await resolveEffects();

const effectIcons = await Promise.all(
  effects.map((effect) => resolveEffectIcon(effect.id)),
);
---

<StarlightPage
  frontmatter={{
    title: "Effects",
    description: `A list of all effects.`,
  }}
>
  <ItemList itemHeight="150px">
    {
      effects.map((effect, i) => (
        <ItemListItem
          title={effect.data.name}
          href={getEffectHref(effect.id)}
          icon={effectIcons[i]}
        />
      ))
    }
  </ItemList>
</StarlightPage>
<style>
  .effects-layout {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 8px;
  }

  @media (max-width: 600px) {
    .effects-layout {
      justify-content: center;
    }
  }

  .effects-item-icon {
    margin-top: auto;
    margin-bottom: auto;
  }
</style>
