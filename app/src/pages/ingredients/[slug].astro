---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

import { resolveIngredientIcon } from "../../content/ingredients/resolve-ingredient-icon";
import IngredientPath from "../../components/IngredientPath.astro";

export async function getStaticPaths() {
  const ingredients = await getCollection("ingredients");
  return ingredients.map((i) => ({
    params: { slug: i.id },
    props: { ingredient: i },
  }));
}

const { ingredient } = Astro.props;
const { name, basePrice, path } = ingredient.data;

const [{ Content }, resolvedIcon] = await Promise.all([
  render(ingredient),
  resolveIngredientIcon(ingredient.id),
]);
---

<StarlightPage
  frontmatter={{
    title: name,
    description: `The ${name} ingredient.`,
  }}
>
  <div class="ingredient-layout">
    <aside class="ingredient-infobox">
      {
        resolvedIcon && (
          <div class="icon-wrapper">
            <Image src={resolvedIcon} alt={name} width={64} />
          </div>
        )
      }
      <dl>
        <dt>Base Price</dt>
        <dd>{basePrice}</dd>
        <dt>Path</dt>
        <dd>
          <IngredientPath path={path} size={200} icon={resolvedIcon?.src} />
        </dd>
      </dl>
    </aside>

    <div class="ingredient-body">
      <Content />
    </div>
  </div>
</StarlightPage>

<style>
  .ingredient-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--sl-content-pad-x);
  }

  .ingredient-infobox {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    padding: 1rem;
    height: fit-content;
  }

  .icon-wrapper {
    border-radius: 0.25rem;
    padding: 0.5rem;
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  dt {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  dd {
    font-weight: 600;
    margin: 0 0 0.75rem 0;
  }
</style>
