---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

import { resolveIngredientIcon } from "../../content/ingredients/resolve-ingredient-icon";
import IngredientPath from "../../components/IngredientPath.astro";
import { Code } from "astro:components";

export async function getStaticPaths() {
  const ingredients = await getCollection("ingredients");
  const items = ingredients.map((ingredient) => ({
    params: { slug: ingredient.id },
    props: { ingredient: ingredient },
  }));
  console.log(JSON.stringify(items, null, 2));
  return items;
}

const { ingredient } = Astro.props;
const { id } = ingredient;
const { name, basePrice, path } = ingredient.data;

const [{ Content }, resolvedIcon] = await Promise.all([
  render(ingredient),
  resolveIngredientIcon(id),
]);
---

<StarlightPage
  frontmatter={{
    title: name,
    description: `The ${name} ingredient.`,
  }}
  headings={[{ depth: 2, slug: "svg-path", text: "SVG Path" }]}
>
  <div class="ingredient-layout">
    <aside class="ingredient-infobox">
      {
        resolvedIcon && (
          <div class="icon-wrapper">
            <Image src={resolvedIcon} alt={name} width={64} />
          </div>
        )
      }
      <dl>
        <dt>Base Price</dt>
        <dd>{basePrice}</dd>
        <dt>Path</dt>
        <dd>
          <IngredientPath path={path} size={200} icon={resolvedIcon?.src} />
        </dd>
      </dl>
    </aside>

    <div class="ingredient-body">
      <Content />
      <div>
        <h4 id="svg-path">SVG Path</h4>
        <Code wrap code={path} />
      </div>
    </div>
  </div>
</StarlightPage>

<style>
  .ingredient-layout {
    /* display: grid; */
    /* grid-template-columns: 200px 1fr; */
    display: flex;
    flex-direction: row;
    gap: var(--sl-content-pad-x);
    max-width: 100%;
  }

  .ingredient-infobox {
    width: 200px;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    padding: 1rem;
    height: fit-content;
  }

  .ingredient-body {
    flex: 1 1 auto;
    min-width: 0;
  }

  .icon-wrapper {
    border-radius: 0.25rem;
    padding: 0.5rem;
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  dt {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  dd {
    font-weight: 600;
    margin: 0 0 0.75rem 0;
  }
</style>
