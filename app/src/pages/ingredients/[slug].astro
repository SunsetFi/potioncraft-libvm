---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import { Code } from "astro:components";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

import { resolveIngredientIcon } from "../../content/ingredients/resolve-ingredient-icon";
import IngredientPath from "../../components/IngredientPath.astro";
import { getRecipesByIngredient } from "../../content/recipes/recipes-by-ingredient";
import RecipesTable from "../../components/RecipesTable.astro";
import ExpandableContent from "../../components/ExpandableContent.astro";

export async function getStaticPaths() {
  const ingredients = await getCollection("ingredients");
  const items = ingredients.map((ingredient) => ({
    params: { slug: ingredient.id },
    props: { ingredient: ingredient },
  }));
  return items;
}

const { ingredient } = Astro.props;
const { id } = ingredient;
const { name, basePrice, path } = ingredient.data;

const [{ Content }, resolvedIcon, recipes] = await Promise.all([
  render(ingredient),
  resolveIngredientIcon(id),
  getRecipesByIngredient(id),
]);
---

<StarlightPage
  frontmatter={{
    title: name,
    description: `The ${name} ingredient.`,
  }}
  headings={[
    { depth: 2, slug: "path", text: "Path" },
    { depth: 2, slug: "svg-path", text: "SVG Path" },
    { depth: 2, slug: "ingredient-recipes", text: "Recipes" },
  ]}
>
  <div class="ingredient-layout">
    <aside class="ingredient-infobox">
      {
        resolvedIcon && (
          <div class="icon-wrapper">
            <Image src={resolvedIcon} alt={name} width={64} />
          </div>
        )
      }
      <dl>
        <dt>Base Price</dt>
        <dd>{basePrice}</dd>
      </dl>
    </aside>

    <div class="ingredient-body">
      <Content />
      {ingredient.body != null ? <hr /> : null}
      <h3 id="path">Path</h3>
      <div class="ingredient-path-preview">
        <IngredientPath size={200} ingredient={ingredient} />
      </div>
      <ExpandableContent id="svg-path" title="SVG Path" collapsed={true}>
        <Code wrap code={path} />
      </ExpandableContent>
      <ExpandableContent
        id="ingredient-recipes"
        title="Recipes using this Ingredient"
      >
        <RecipesTable recipes={recipes} />
      </ExpandableContent>
    </div>
  </div>
</StarlightPage>

<style>
  .ingredient-layout {
    display: flex;
    flex-direction: row-reverse;
    gap: var(--sl-content-pad-x);
    max-width: 100%;
  }

  .ingredient-infobox {
    width: 250px;
    flex: 0 0 auto;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    padding: 1rem;
    height: fit-content;
  }

  .ingredient-body {
    flex: 1 1 auto;
    min-width: 0;
  }

  .icon-wrapper {
    border-radius: 0.25rem;
    padding: 0.5rem;
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .ingredient-path-preview {
    display: flex;
    justify-content: center;
  }

  dt {
    text-align: center;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  dd {
    text-align: center;
    font-weight: 600;
    margin: 0;
    padding: 0;
  }
</style>
