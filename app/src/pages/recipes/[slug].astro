---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import EffectList from "../../components/EffectList.astro";
import IngredientList from "../../components/IngredientList.astro";
import { resolveRecipePreview } from "../../content/recipes/resolve-recipe-preview";
import {
  getPrimaryIngredientTag,
  getPrimarySaltTag,
} from "../../content/tags/primary-tag";
import { resolveTag } from "../../content/tags/resolve-tag";
import RecipeTagsList from "../../components/RecipeTagsList.astro";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes");
  return recipes.map((i) => ({
    params: { slug: i.id },
    props: { recipe: i },
  }));
}

const { recipe } = Astro.props;
const { id } = recipe;
const [{ Content }, preview] = await Promise.all([
  render(recipe),
  resolveRecipePreview(id),
]);
const { name, cost, effects, ingredients, tags } = recipe.data;

const primaryIngredientTag = getPrimaryIngredientTag(tags);
const primarySaltTag = getPrimarySaltTag(tags);

const [primaryIngredientTagData, primarySaltTagData] = await Promise.all([
  primaryIngredientTag ? resolveTag(primaryIngredientTag) : null,
  primarySaltTag ? resolveTag(primarySaltTag) : null,
]);

let titleDescriptor: string = "";

if (primaryIngredientTagData) {
  if (primarySaltTagData) {
    titleDescriptor = `${primarySaltTagData.data.name} ${primaryIngredientTagData.data.name}`;
  } else {
    titleDescriptor = primaryIngredientTagData.data.name;
  }
} else if (primarySaltTagData) {
  titleDescriptor = primarySaltTagData.data.name;
} else {
  titleDescriptor = "Unknown";
}
---

<StarlightPage
  frontmatter={{
    title: `${titleDescriptor} Recipe`,
    description: `The ${name} recipe.`,
  }}
>
  <div class="recipe-layout">
    <aside class="recipe-infobox">
      <dl>
        <dt>Cost</dt>
        <dd>{cost}</dd>
        <dt>Effects</dt>
        <dd>
          <EffectList effects={effects} />
        </dd>
      </dl>
      <dt>Tags</dt>
      <dd>
        <RecipeTagsList tags={tags} />
      </dd>
      <dt>Ingredients</dt>
      <dd>
        <IngredientList ingredients={ingredients} count />
      </dd>
    </aside>
    {
      preview && (
        <Image
          class="recipe-preview"
          src={preview}
          alt={name}
          width={400}
          height={400}
        />
      )
    }
    <div class="recipe-body">
      <Content />
    </div>
  </div>
</StarlightPage>

<style>
  .recipe-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--sl-content-pad-x);
  }

  .recipe-infobox {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    padding: 1rem;
    height: fit-content;
  }

  .recipe-effect-icon {
    display: inline-block;
    margin-right: 4px;
  }
</style>
