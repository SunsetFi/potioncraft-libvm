---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import EffectList from "../../components/EffectList.astro";
import IngredientList from "../../components/IngredientList.astro";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes");
  return recipes.map((i) => ({
    params: { slug: i.id },
    props: { recipe: i },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const { name, cost, datastring, effects, ingredients, tags } = recipe.data;
---

<StarlightPage
  frontmatter={{
    title: name,
    description: `The ${name} recipe.`,
  }}
>
  <div class="recipe-layout">
    <aside class="recipe-infobox">
      <dl>
        <dt>Cost</dt>
        <dd>{cost}</dd>
        <dt>Effects</dt>
        <dd>
          <EffectList effects={effects} />
        </dd>
      </dl>
      <dt>Tags</dt>
      <dd>
        {tags.map((tag) => <span>{tag}</span>) ?? <span>None</span>}
      </dd>
      <dt>Ingredients</dt>
      <dd>
        <IngredientList ingredients={ingredients} count />
      </dd>
    </aside>
    <Image
      class="recipe-preview"
      src={`http://localhost:8080/api/plotter-preview.png?data=${datastring}`}
      alt={name}
      width={400}
      height={400}
    />
    <div class="recipe-body">
      <Content />
    </div>
  </div>
</StarlightPage>

<style>
  .recipe-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--sl-content-pad-x);
  }

  .recipe-infobox {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    padding: 1rem;
    height: fit-content;
  }

  .recipe-effect-icon {
    display: inline-block;
    margin-right: 4px;
  }
</style>
