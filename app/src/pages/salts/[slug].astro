---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

import { resolveSaltIcon } from "../../content/salts/resolve-salt-icon";
import { getRecipesBySalt } from "../../content/recipes/recipes-by-salt";

import RecipesTable from "../../components/RecipesTable.astro";
import ExpandableContent from "../../components/ExpandableContent.astro";

export async function getStaticPaths() {
  const salts = await getCollection("salts");
  return salts.map((effect) => ({
    params: { slug: effect.id },
    props: { salt: effect },
  }));
}

const { salt } = Astro.props;
const { id } = salt;
const { name, pricePerGrain } = salt.data;

const [{ Content }, resolvedIcon, recipes] = await Promise.all([
  render(salt),
  resolveSaltIcon(id),
  getRecipesBySalt(id),
]);
---

<StarlightPage
  frontmatter={{
    title: name,
    description: name,
  }}
  headings={[{ depth: 2, slug: "salt-recipies", text: "Recipes" }]}
>
  <div class="salt-layout">
    <aside class="salt-infobox">
      {
        resolvedIcon && (
          <div class="icon-wrapper">
            <Image src={resolvedIcon} alt={name} width={64} />
          </div>
        )
      }
      <dl>
        <dt>Price Per Grain</dt>
        <dd>{pricePerGrain}</dd>
      </dl>
    </aside>

    <div class="salt-body">
      <Content />
      {salt.body != null ? <hr /> : null}
      <ExpandableContent
        id="salt-recipes"
        title="Recipes using this Salt"
        collapsed={true}
      >
        <RecipesTable recipes={recipes} />
      </ExpandableContent>
    </div>
  </div>
</StarlightPage>

<style>
  .salt-layout {
    min-height: 200px;
  }

  .salt-infobox {
    float: right;
    width: 200px;
    margin-left: var(--sl-content-pad-x);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    padding: 1rem;
    height: fit-content;
  }

  .icon-wrapper {
    border-radius: 0.25rem;
    padding: 0.5rem;
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  dt {
    text-align: center;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  dd {
    text-align: center;
    font-weight: 600;
    margin: 0;
    padding: 0;
  }
</style>
